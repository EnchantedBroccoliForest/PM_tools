      { "id": "claim.outcome.0.win", "category": "outcome_win", "text": "Yes wins.", "sourceRefs": [] },
      { "id": "claim.source.0", "category": "source", "text": "https://fake.invalid/does-not-exist", "sourceRefs": [] }
