{
  "id": "num-invalid-date",
  "bucket": "numerical-date",
  "description": "Timestamp claim says \"March 32, 2027\" with no ISO date and no HH:MM. Structural verifier hard_fails it; tool-output style check catches impossible calendar dates.",
  "input": {
    "question": "Will the referenced event occur by March 32, 2027?",
    "startDate": "2027-01-01",
    "endDate": "2027-03-31",
    "references": "https://example.com/feed"
  },
  "mockResponses": {
    "claims": [
      { "id": "claim.question.0", "category": "question", "text": "Will the referenced event occur by March 32, 2027?", "sourceRefs": [] },
      { "id": "claim.timestamp.start", "category": "timestamp", "text": "Market starts 2027-01-01T00:00:00Z.", "sourceRefs": [] },
      { "id": "claim.timestamp.end", "category": "timestamp", "text": "Market ends March 32, 2027 (sic).", "sourceRefs": [] },
      { "id": "claim.outcome.0.win", "category": "outcome_win", "text": "Yes wins.", "sourceRefs": [] },
      { "id": "claim.source.0", "category": "source", "text": "https://example.com/feed", "sourceRefs": [] }
    ],
    "entailment": [
      { "id": "claim.question.0", "entailment": "entailed", "rationale": "Present." },
      { "id": "claim.timestamp.start", "entailment": "entailed", "rationale": "Present." },
      { "id": "claim.timestamp.end", "entailment": "entailed", "rationale": "Present." },
      { "id": "claim.outcome.0.win", "entailment": "entailed", "rationale": "Present." },
      { "id": "claim.source.0", "entailment": "entailed", "rationale": "Present." }
    ]
  },
  "expectedProperties": {
    "expected_has_hard_fail": true,
    "expected_routing_overall": "blocked",
    "expected_finalize_allowed": false,
    "expected_blocked_by_verification": true,
    "expected_blocked_by_routing": true
  }
}
