{
  "id": "advf-contradicted-date",
  "bucket": "adversarial-factual",
  "description": "The extractor produced an end-time claim that disagrees with the draft — entailment verifier must flag it as contradicted and the Accept gate must block on verification hard_fail.",
  "input": {
    "question": "Will the referenced event occur by 2027-12-31?",
    "startDate": "2027-01-01",
    "endDate": "2027-12-31",
    "references": "https://example.com/feed"
  },
  "mockResponses": {
    "entailment": [
      { "id": "claim.question.0", "entailment": "entailed", "rationale": "Present." },
      { "id": "claim.timestamp.start", "entailment": "entailed", "rationale": "Present." },
      { "id": "claim.timestamp.end", "entailment": "contradicted", "rationale": "Draft says 2027-12-31 but claim extractor emitted 2028-01-15." },
      { "id": "claim.outcome.0.win", "entailment": "entailed", "rationale": "Present." },
      { "id": "claim.outcome.0.criterion", "entailment": "entailed", "rationale": "Present." },
      { "id": "claim.outcome.1.win", "entailment": "entailed", "rationale": "Present." },
      { "id": "claim.outcome.1.criterion", "entailment": "entailed", "rationale": "Present." },
      { "id": "claim.source.0", "entailment": "entailed", "rationale": "Present." },
      { "id": "claim.threshold.0", "entailment": "entailed", "rationale": "Present." }
    ]
  },
  "expectedProperties": {
    "expected_has_hard_fail": true,
    "expected_has_contradicted": true,
    "expected_routing_overall": "blocked",
    "expected_finalize_allowed": false,
    "expected_blocked_by_verification": true,
    "expected_blocked_by_routing": true,
    "expected_blocking_count": "gte-1"
  }
}
