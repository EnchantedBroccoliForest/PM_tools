{
  "name": "pm-tools",
  "version": "0.1.0",
  "description": "Headless prediction market drafting and review CLI for 42.space market proposals.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "bin": {
    "pm-tools": "bin/pm-tools.js",
    "pm-tools-service": "bin/pm-tools-service.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE",
    "!src/**/*.test.js",
    "!src/**/*.test.jsx",
    "!src/**/__snapshots__/"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EnchantedBroccoliForest/42_creator_tool.git"
  },
  "bugs": {
    "url": "https://github.com/EnchantedBroccoliForest/42_creator_tool/issues"
  },
  "homepage": "https://github.com/EnchantedBroccoliForest/42_creator_tool#readme",
  "keywords": [
    "prediction-market",
    "cli",
    "openrouter",
    "42-space",
    "market-drafting"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "pm-tools": "node bin/pm-tools.js",
    "serve": "node bin/pm-tools-service.js",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "node eval/run.js",
    "eval:baseline": "node eval/run.js --baseline --quiet",
    "eval:check": "node eval/run.js --check-regression --quiet"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.2.4",
    "vitest": "^4.1.4"
  }
}
